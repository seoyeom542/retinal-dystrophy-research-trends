# NCBI Entrez requires an email address with every request.
# An API key is optional but raises the rate limit from 3 to 10 requests/sec.
# Get a key at: https://www.ncbi.nlm.nih.gov/account/  ->  Settings -> API Key Management
# Copy this file to ".env" and fill in your values.

NCBI_EMAIL=your-email@example.com
NCBI_API_KEY=
